# --- Database ---

#   postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
#
# Vercel / serverless: use Supabase TRANSACTION POOLER (port 6543), not db.xxx:5432.
# Supabase → Project Settings → Database → Connection string → "Transaction pooler"
# Append (if not already): ?pgbouncer=true&connection_limit=1
# Example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Must match the site URL. Local: http://localhost:3000
# Vercel production example: https://trip-wayz.vercel.app (no trailing slash, use https)
NEXTAUTH_URL="http://localhost:3000"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Profile avatars (server only). Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
